# Required runtime settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional runtime settings
# Optional manual override. Leave empty to use the default TRON mainnet RPC.
TRON_RPC_URL=
# x402 settlement endpoint.
X402_FACILITATOR_URL=https://facilitator.bankofai.io
# Facilitator auth for higher rate limits. Sent as X-API-KEY.
FACILITATOR_API_KEY=MAIN_API_KEY
# Business knobs (currently not enforced by all flows).
SERVICE_FEE_TRX=0
RATE_LIMIT_PER_MINUTE=10

# Registration-only settings (NOT required to run MCP service)
# Fill these only when running scripts/register_8004.py.
ERC8004_AGENT_ID=
AGENT_OPERATOR_KEY=

# The runtime is fixed to TRON mainnet.
