# Required runtime settings
AINFT_ENV=dev
NETWORK=mainnet
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional runtime settings
# Force explicit API domains only when needed. Normally these are derived from AINFT_ENV.
AINFT_API_URL=
AINFT_WEB_URL=
# Default RPC endpoint for TRON mainnet.
TRON_RPC_URL=https://api.trongrid.io
# x402 settlement endpoint.
X402_FACILITATOR_URL=https://facilitator.bankofai.io

# AINFT merchant API for post-topup confirmation (optional but recommended).
# If set, server will call the merchant recharge confirmation API after payment success.
AINFT_MERCHANT_ID=
AINFT_MERCHANT_KEY=
# Optional override. Default uses <ainftApiUrl>/m/credit/recharge from network config.
AINFT_TOPUP_CONFIRM_URL=
AINFT_TOPUP_CONFIRM_TIMEOUT_MS=12000
AINFT_TOPUP_CONFIRM_RETRIES=4
AINFT_TOPUP_CONFIRM_INTERVAL_MS=1500
# Business knobs (currently not enforced by all flows).
SERVICE_FEE_TRX=0
RATE_LIMIT_PER_MINUTE=10

# Registration-only settings (NOT required to run MCP service)
# Fill these only when running scripts/render_registration.py,
# scripts/register_8004.py, or scripts/update_8004.py.
ERC8004_AGENT_ID=
AGENT_OPERATOR_KEY=
AINFT_PUBLIC_MCP_ENDPOINT=https://ainft-agent.bankofai.io/mcp
PINATA_JWT=
PINATA_GATEWAY=

# AINFT_ENV values: dev | prod
# NETWORK values: mainnet | nile | bsc | bsc-testnet
# Dev can still use chat-dev API while keeping production-chain recharge addresses.
# AINFT addresses are loaded from config/networks.json by NETWORK.
