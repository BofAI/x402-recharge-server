# Required runtime settings
# Public brand is BofAI. Runtime keeps the legacy AINFT_ENV variable.
# Default to production. Use AINFT_ENV=dev only for local Nile testing.
AINFT_ENV=prod
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional runtime settings
# Optional manual override. Leave empty to use the default RPC for the selected AINFT_ENV.
TRON_RPC_URL=
# x402 settlement endpoint.
X402_FACILITATOR_URL=https://facilitator.bankofai.io
# Facilitator auth for higher rate limits. Sent as X-API-KEY.
FACILITATOR_API_KEY=MAIN_API_KEY
# Business knobs (currently not enforced by all flows).
SERVICE_FEE_TRX=0
RATE_LIMIT_PER_MINUTE=120
# Request limits
REQUEST_BODY_MAX_BYTES=1048576
# Facilitator timeouts/retries
FACILITATOR_TIMEOUT_SECONDS=10
FACILITATOR_VERIFY_RETRIES=1
FACILITATOR_RETRY_BACKOFF_SECONDS=0.5
FACILITATOR_SETTLE_TIMEOUT_SECONDS=120

# Registration-only settings (NOT required to run MCP service)
# Fill these only when running scripts/register_8004.py.
ERC8004_AGENT_ID=
AGENT_OPERATOR_KEY=
TRON_AGENT_OPERATOR_KEY=
BSC_AGENT_OPERATOR_KEY=

# AINFT_ENV values: dev | prod
# Network, deposit address, and token contracts are derived from AINFT_ENV.
