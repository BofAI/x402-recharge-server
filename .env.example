# Required runtime settings
NETWORK=mainnet
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional runtime settings
# Default RPC endpoint for TRON mainnet.
TRON_RPC_URL=https://api.trongrid.io
# Optional API key to avoid strict public rate limits.
TRONGRID_API_KEY=
# Business knobs (currently not enforced by all flows).
SERVICE_FEE_TRX=0
RATE_LIMIT_PER_MINUTE=10

# Registration-only settings (NOT required to run MCP service)
# Fill these only when running scripts/register_8004.py.
ERC8004_AGENT_ID=
AGENT_OPERATOR_KEY=

# AINFT addresses are loaded from config/networks.json (mainnet only).
