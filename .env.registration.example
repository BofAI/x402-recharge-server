# ERC-8004 registration handoff template
# Copy this to .env when preparing bootstrap upload + mainnet registration.

# External AINFT environment
AINFT_ENV=prod

# ERC-8004 registration target network
# Supported here: mainnet | nile
NETWORK=mainnet

# Optional TRON RPC override for registration scripts
TRON_RPC_URL=https://api.trongrid.io

# Public MCP endpoint written into registration metadata
AINFT_PUBLIC_MCP_ENDPOINT=https://ainft-agent.bankofai.io/mcp

# Optional public web URL override for metadata rendering
# Leave empty to derive from AINFT_ENV
AINFT_WEB_URL=

# Pinata JWT for IPFS uploads
PINATA_JWT=

# Optional custom gateway base, for example:
# PINATA_GATEWAY=https://gateway.pinata.cloud
PINATA_GATEWAY=

# TRON private key for ERC-8004 register/update transactions
AGENT_OPERATOR_KEY=

# Filled after first registration succeeds
ERC8004_AGENT_ID=
